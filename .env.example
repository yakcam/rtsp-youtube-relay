# Copy to .env and fill in real values. Then `chmod 600 .env`.
# .env is gitignored.

# RTSP source URL for the camera. Use the IP address, NOT a hostname —
# DNS may not be available immediately on NAS boot, which would crash-loop the relay.
# Example for a generic IP cam:
#   rtsp://192.168.2.8:554/user=admin&password=&channel=1&stream=0.sdp?real_stream
RTSP_URL=rtsp://USER:PASS@192.168.2.8:554/STREAM_PATH

# Full RTMP destination URL, INCLUDING the stream key as the final path segment.
# The relay simply forwards to whatever you put here, so any RTMP ingest works.
#
# YouTube Live:
#   rtmp://a.rtmp.youtube.com/live2/xxxx-xxxx-xxxx-xxxx-xxxx
# Twitch (regional ingests at https://ingest.twitch.tv/ingests):
#   rtmp://live.twitch.tv/app/live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Local mediamtx for testing (no key, just a path):
#   rtmp://192.168.1.50:1935/test
RTMP_URL=rtmp://a.rtmp.youtube.com/live2/xxxx-xxxx-xxxx-xxxx-xxxx
